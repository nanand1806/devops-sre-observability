# Copy to terraform.tfvars and adjust. terraform.tfvars is gitignored.
aws_region      = "us-east-1"
project_name    = "demo-app"
environment     = "dev"
vpc_cidr        = "10.0.0.0/16"
container_image = "public.ecr.aws/nginx/nginx:stable"
container_port  = 80
desired_count   = 2
task_cpu        = 256
task_memory     = 512
