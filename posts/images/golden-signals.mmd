flowchart TB
    subgraph nr["New Relic"]
        c1["Latency p95"]
        c2["Error rate"]
        c3["Traffic drop"]
        c4["Host CPU saturation"]
        pol["Alert policy"]
        wf["Workflow"]
        c1 & c2 & c3 & c4 --> pol
        pol -->|issues| wf
    end
    wf --> slack["Slack channel"]
    wf --> teams["Teams channel"]
    slack --> sl[("Slack webhook")]
    teams --> tm[("Teams webhook")]

    classDef signal fill:#1CE783,stroke:#0a8f5a,stroke-width:1px,color:#000;
    classDef slackc fill:#4A154B,stroke:#2d0d2e,color:#fff;
    classDef teamsc fill:#5059C9,stroke:#343a99,color:#fff;
    class c1,c2,c3,c4 signal;
    class slack,sl slackc;
    class teams,tm teamsc;
